# Coverage config. Excludes defensive/unreachable branches (bad-value guards,
# missing-datapoint fallbacks) so the reported figure reflects reachable code.
[run]
source = custom_components/junghome

[report]
fail_under = 95
show_missing = true
exclude_also =
    if TYPE_CHECKING:
    except \(TypeError, ValueError\):
    except Exception:
    if not datapoint:
    if not self\._brightness_datapoint_id:
    if not self\._color_temp_datapoint_id:
